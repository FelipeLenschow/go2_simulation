<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:macro name="gz_simulation">

    <!-- ROS 2 Control Plugin for Gazebo -->
    <gazebo>
      <plugin filename="libgz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
        <parameters>$(find go2_description)/config/go2_sim.yaml</parameters>
        <update_rate>1000</update_rate>  <!-- Runs simulation at 1000Hz -->
      </plugin>
    </gazebo>

    <!-- IMU Sensor in Gazebo -->
    <gazebo reference="imu">
      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>4</update_rate>  
        <visualize>true</visualize> 
        <topic>imu</topic>
      </sensor>
    </gazebo>

